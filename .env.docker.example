# Example variables for Docker Compose (copy to `.env` if you use compose variable substitution).
# Do not put real secrets in tracked files.

# Frontend service — Next.js proxies /svc/api/* to this URL from inside the frontend container.
# BACKEND_INTERNAL_URL=http://backend:8000

# Optional: override public API base (default in app is /svc/api).
# Use /svc/api with Docker so requests stay same-origin and hit the rewrite proxy.
# NEXT_PUBLIC_BACKEND_URL=/svc/api

# Backend — browser origins trusted for CSRF-protected requests (admin login,
# session auth). Set to your real https:// domain in production.
# DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Backend — set to production to hide /docs, /redoc, and /openapi.json (prod Compose sets this).
# DJANGO_ENVIRONMENT=development

# Backend — set to 1 when a TLS-terminating proxy (ALB, nginx) fronts the stack:
# enables secure cookies, HSTS, and X-Forwarded-Proto trust.
# DJANGO_HTTPS=0

# Production backend (docker-compose.prod.yml): REQUIRED — compose refuses to
# start without it. Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# DJANGO_SECRET_KEY=

# Production database password (docker-compose.prod.yml): REQUIRED — compose
# refuses to start without it. Dev Compose uses fixed app/app credentials.
# POSTGRES_PASSWORD=

# Backend database (optional override). Compose sets this to the postgres
# service; unset it to fall back to a local SQLite file (no-Docker quickstart).
# DATABASE_URL=postgres://app:app@db:5432/app

# Docker bind mounts (compose sets these): reliable dev reload on Windows/macOS.
# WATCHPACK_POLLING=true
# DOCKER_DEV=true
